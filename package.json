{
  "name": "kw-plugin",
  "version": "0.19.0",
  "description": "Claude Code plugin: code reviews, PR creation, team analytics, release management",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "prebuild": "node scripts/sync-version.mjs",
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=11.9.0"
  },
  "author": "Kevin Wiggen",
  "license": "MIT",
  "private": true,
  "dependencies": {
    "@google/genai": "^2.8.0",
    "jsonc-parser": "^3.3.1",
    "marked": "^18.0.5",
    "shiki": "^4.2.0",
    "simpledotcss": "^2.3.7"
  }
}
